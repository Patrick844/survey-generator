# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for real LLM mode
OPENAI_API_KEY=your_openai_api_key_here

# Optional. Change this to the OpenAI model you want to use.
OPENAI_MODEL=gpt-4o-mini

# Set to true only for local tests or demos without API calls.
OPENAI_FAKE_MODE=false

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/survey

# ── Service URLs ──────────────────────────────────────────────────────────────
# Used by Streamlit frontend to reach the FastAPI backend
BACKEND_URL=http://127.0.0.1:8000

# Used by the backend to build the survey_url returned to the admin.
# Must be the public address of the Streamlit frontend.
FRONTEND_URL=http://localhost:8501
