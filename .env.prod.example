# ─────────────────────────────────────────────────────────────────────────────
# Production overrides for a public deployment (e.g. an EC2 instance).
#
# Copy this file to `.env.prod`, replace <PUBLIC_HOST> with your server's public
# IP or domain, then deploy with:
#
#     docker compose --env-file .env.prod up -d --build
#
# These values are read by docker-compose.yml for variable substitution. Your
# OpenAI key stays in survey/.env — it does NOT go here.
# ─────────────────────────────────────────────────────────────────────────────

# Backend URL the admin's browser calls (baked into the React bundle at build).
VITE_API_BASE=http://<PUBLIC_HOST>:8000

# Public Streamlit address the backend puts into the shareable employee links.
FRONTEND_URL=http://<PUBLIC_HOST>:8501
